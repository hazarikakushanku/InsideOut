{
  "expo": {
    "name": "InsideOut",
    "slug": "insideout",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "insideout",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.insideout.app"
    },
    "web": {},
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan products."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
